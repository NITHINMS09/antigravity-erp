{
  "name": "antigravity-erp-backend",
  "version": "1.0.0",
  "description": "Antigravity ERP Backend - Multi-Business Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./node_modules/prisma/build/index.js generate && tsc",
    "start": "node dist/index.js",
    "db:push": "node ./node_modules/prisma/build/index.js db push",
    "db:studio": "node ./node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "prisma": "^6.9.0",
    "typescript": "^5.8.3",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4"
  }
}
